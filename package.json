{
  "name": "@bguiz/ainj",
  "version": "0.2.3",
  "description": "An AI SDK for Injective",
  "keywords": ["injective", "AI", "agent-skills", "skills", "MCP", "CLI", "SDK"],
  "engines": {
    "node": ">=24.0.0"
  },
  "homepage": "https://github.com/bguiz/ainj#readme",
  "bugs": {
    "url": "https://github.com/bguiz/ainj/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bguiz/ainj.git"
  },
  "license": "MIT",
  "author": "bguiz",
  "type": "module",
  "bin": {
    "ainj": "src/cli/index.js"
  },
  "main": "src/lib/ainj.js",
  "files": ["ainj.config.json", "src/", "scripts/", "!src/**/*.test.js", "!scripts/**/*.test.js"],
  "dependencies": {
    "@clack/prompts": "0.9.1",
    "@injective-agent/core": "github:InjectiveLabs/mcp-server#a5fe59f1310a579f0569627fee2c7bef59d913d0",
    "injective-core": "1.18.0",
    "smol-toml": "1.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "c8": "10.1.3",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "scripts": {
    "test": "node --test --experimental-test-module-mocks",
    "lint": "biome check .",
    "sync:skills": "node scripts/sync-skills.js",
    "list-files": "npm pack && tar -xvzf *.tgz && rm -rf package *.tgz"
  }
}
